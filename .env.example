# URL to the main application (used for "Get Started" buttons)
APP_URL=https://app.example.com

# Postgres connection string (Neon / Postgres)
DATABASE_URL=postgresql://username:password@host:5432/postgres

# Redis connection string (used for caching)
REDIS_URL=redis://localhost:6379

# Donkey SEO Integration
# Project ID from your Donkey SEO dashboard
DONKEY_SEO_PROJECT_ID=your_project_id_here
# API key for Donkey SEO integration endpoints
DONKEY_SEO_API_KEY=your_api_key_here
# Webhook signing secret for verifying webhook requests
DONKEY_SEO_WEBHOOK_SECRET=your_webhook_secret_here

# Admin API protection
# Generate a secure random token for admin endpoints
ADMIN_API_TOKEN=generate_random_secure_token_here
