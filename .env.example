# URL to the main application (used for "Get Started" buttons)
APP_URL=https://app.example.com

# Postgres connection string (Vercel + Supabase). Use the pooled URL.
# The app also supports DATABASE_URL / POSTGRES_URL / DATABASE_POSTGRES_URL_NON_POOLING.
DATABASE_POSTGRES_URL=postgresql://username:password@host:5432/postgres
